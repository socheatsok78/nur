From 22752a20dc397d0157b4369605a90429fdeedbff Mon Sep 17 00:00:00 2001
From: Socheat <github@socheat.dev>
Date: Mon, 29 Jun 2026 11:13:23 +0700
Subject: [PATCH 1/2] Implement UTF-8 sanitization for audio device names

Add a function to sanitize audio device names to valid UTF-8.

Ref: https://github.com/AlexandreRouma/SDRPlusPlus/compare/master...aurimasniekis:SDRPlusPlus:audio_sink_fix
---
 sink_modules/audio_sink/src/main.cpp | 65 ++++++++++++++++++++++++++++
 1 file changed, 65 insertions(+)

diff --git a/sink_modules/audio_sink/src/main.cpp b/sink_modules/audio_sink/src/main.cpp
index 9ac793bb79..19e2d541aa 100644
--- a/sink_modules/audio_sink/src/main.cpp
+++ b/sink_modules/audio_sink/src/main.cpp
@@ -12,6 +12,70 @@
 
 #define CONCAT(a, b) ((std::string(a) + b).c_str())
 
+// Sanitize a string to well-formed UTF-8. The OS can report audio device names
+// in a non-UTF-8 encoding (e.g. Latin-1), which would later make the JSON config
+// serializer throw and crash the autosave thread. We keep valid UTF-8 sequences
+// as-is and transcode any stray byte >= 0x80 as if it were Latin-1, so the stored
+// name stays a stable, lossless key that still matches the runtime device name.
+static std::string sanitizeUTF8(const std::string& str) {
+    std::string out;
+    out.reserve(str.size());
+    size_t i = 0;
+    const size_t n = str.size();
+    while (i < n) {
+        const unsigned char c = static_cast<unsigned char>(str[i]);
+        int len = 0;
+        unsigned char lower = 0x80, upper = 0xBF;
+        if (c < 0x80) {
+            out += static_cast<char>(c);
+            i++;
+            continue;
+        }
+        if (c >= 0xC2 && c <= 0xDF) { len = 1; }
+        else if (c == 0xE0) {
+            len = 2;
+            lower = 0xA0;
+        }
+        else if (c >= 0xE1 && c <= 0xEC) { len = 2; }
+        else if (c == 0xED) {
+            len = 2;
+            upper = 0x9F;
+        }
+        else if (c >= 0xEE && c <= 0xEF) { len = 2; }
+        else if (c == 0xF0) {
+            len = 3;
+            lower = 0x90;
+        }
+        else if (c >= 0xF1 && c <= 0xF3) { len = 3; }
+        else if (c == 0xF4) {
+            len = 3;
+            upper = 0x8F;
+        }
+        else { len = -1; }
+
+        bool valid = len > 0 && i + len < n;
+        for (int j = 1; valid && j <= len; j++) {
+            const unsigned char cc = static_cast<unsigned char>(str[i + j]);
+            const unsigned char lo = (j == 1) ? lower : 0x80;
+            const unsigned char hi = (j == 1) ? upper : 0xBF;
+            if (cc < lo || cc > hi) { valid = false; }
+        }
+
+        if (valid) {
+            out.append(str, i, len + 1);
+            i += len + 1;
+        }
+        else {
+            // Invalid byte: transcode it from Latin-1 to a 2-byte UTF-8 sequence.
+            out += static_cast<char>(0xC0 | (c >> 6));
+            out += static_cast<char>(0x80 | (c & 0x3F));
+            i++;
+        }
+    }
+
+    return out;
+}
+
 SDRPP_MOD_INFO{
     /* Name:            */ "audio_sink",
     /* Description:     */ "Audio sink module for SDR++",
@@ -55,6 +119,7 @@ class AudioSink : SinkManager::Sink {
 #endif
             try {
                 info = audio.getDeviceInfo(i);
+                info.name = sanitizeUTF8(info.name);
 #if !defined(RTAUDIO_VERSION_MAJOR) || RTAUDIO_VERSION_MAJOR < 6
                 if (!info.probed) { continue; }
 #endif

